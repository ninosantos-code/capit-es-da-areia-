rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Tours: leitura pública, escrita autenticada
    match /tours/{tourId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Gallery: leitura pública, escrita autenticada
    match /gallery/{imageId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Settings: leitura pública, escrita autenticada
    match /settings/{settingId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Testimonials: leitura pública, criação pública (para envio de depoimentos), 
    // edição/exclusão autenticada
    match /testimonials/{testimonialId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if request.auth != null;
    }

    // Translations: leitura pública, escrita autenticada
    match /translations/{langId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Test connection: leitura/escrita pública (usado para diagnóstico)
    match /test_connection/{docId} {
      allow read, write: if true;
    }
  }
}
